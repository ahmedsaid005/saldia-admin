        let currentEleve = null;

       function showPanel(panelId) {
    document.querySelectorAll('.content-panel').forEach(panel => {
        panel.classList.remove('active');
    });
    document.getElementById(panelId).classList.add('active');
    
    document.querySelectorAll('.nav-btn').forEach(btn => {
        btn.classList.remove('active');
    });
    event.target.classList.add('active');
    
    if (panelId === 'accueil') {
        loadActualites();
    } else if (panelId === 'presenceStats') {
        loadPresenceStats();
    }
}

        async function loadActualites() {
            const container = document.getElementById('actualites');
            const actualites = [
                { date: '2026-04-20', texte: '📚 Les examens du premier semestre débutent le 15 mai 2026' },
                { date: '2026-04-15', texte: '🎓 Réunion parents-professeurs le 25 avril 2026' },
                { date: '2026-04-10', texte: '📝 Les cours de soutien sont disponibles tous les samedis' }
            ];
            
            container.innerHTML = actualites.map(act => `
                <div class="actualite-item">
                    <div class="actualite-date"><i class="far fa-calendar-alt"></i> ${act.date}</div>
                    <div>${act.texte}</div>
                </div>
            `).join('');
        }

        async function loginParent() {
            const matricule = document.getElementById('matriculeLogin').value;
            const dateNaissance = document.getElementById('dateNaissanceLogin').value;
            const nom = document.getElementById('nomLogin').value;
            const telephone = document.getElementById('telephoneLogin').value;
            const email = document.getElementById('emailLogin').value;
            
            const eleveDoc = await db.collection('eleves').doc(matricule).get();
            
            if (eleveDoc.exists) {
                const eleve = eleveDoc.data();
                if (eleve.dateNaissance === dateNaissance && 
                    eleve.nom.toLowerCase() === nom.toLowerCase() &&
                    eleve.telephone === telephone &&
                    eleve.email === email) {
                    
                    currentEleve = { matricule, ...eleve };
                    document.getElementById('loginFormParent').style.display = 'none';
                    document.getElementById('eleveInfo').style.display = 'block';
                    
                    loadEleveInfo();
                } else {
                    alert('Informations incorrectes');
                }
            } else {
                alert('Matricule non trouvé');
            }
        }

      async function loadEleveInfo() {
    if (!currentEleve) return;
    
    // Informations personnelles
    const infoContainer = document.getElementById('infoPersonnelles');
    infoContainer.innerHTML = `
        <table class="info-table">
            <tr><td><i class="fas fa-user"></i> Nom complet</td><td>${currentEleve.nom}</td></tr>
            <tr><td><i class="fas fa-id-card"></i> Matricule</td><td>${currentEleve.matricule}</td></tr>
            <tr><td><i class="fas fa-calendar"></i> Date de naissance</td><td>${currentEleve.dateNaissance}</td></tr>
            <tr><td><i class="fas fa-chalkboard"></i> Classe</td><td>${currentEleve.classe}</td></tr>
            <tr><td><i class="fas fa-phone"></i> Téléphone</td><td>${currentEleve.telephone}</td></tr>
            <tr><td><i class="fas fa-envelope"></i> Email</td><td>${currentEleve.email}</td></tr>
        </table>
    `;
    
    // Bulletins
    const notesSnapshot = await db.collection('notes')
        .where('eleveId', '==', currentEleve.matricule)
        .get();
    
    const bulletinsContainer = document.getElementById('bulletinsEleve');
    if (notesSnapshot.empty) {
        bulletinsContainer.innerHTML = '<p style="color:#6c757d;">Aucun bulletin disponible</p>';
    } else {
        const notesBySemestre = {};
        notesSnapshot.forEach(doc => {
            const note = doc.data();
            if (!notesBySemestre[note.semestre]) {
                notesBySemestre[note.semestre] = [];
            }
            notesBySemestre[note.semestre].push(note);
        });
        
        bulletinsContainer.innerHTML = '';
        for (const [semestre, notes] of Object.entries(notesBySemestre)) {
            let totalNotes = 0;
            let matieres = '';
            notes.forEach(note => {
                const noteValue = note.noteSemestrielle || note.note || 0;
                totalNotes += noteValue;
                matieres += `
                    <div class="bulletin-item">
                        <strong><i class="fas fa-book"></i> ${note.matiere}</strong><br>
                        Note: ${noteValue.toFixed(2)}/20<br>
                        ${note.cc1 ? `CC1: ${note.cc1} | ` : ''}${note.cc2 ? `CC2: ${note.cc2} | ` : ''}${note.compo ? `Comp: ${note.compo}` : ''}
                        ${note.appreciation ? `<br><em>📝 ${note.appreciation}</em>` : ''}
                    </div>
                `;
            });
            
            const moyenneSemestrielle = totalNotes / notes.length;
            bulletinsContainer.innerHTML += `
                <h4 style="margin: 16px 0 8px 0; color:#2c3e50;"><i class="fas fa-chart-simple"></i> Semestre ${semestre}</h4>
                ${matieres}
                <div style="background:#f0f4f8; padding:12px; border-radius:10px; margin-top:8px;">
                    <strong>Moyenne du semestre: ${moyenneSemestrielle.toFixed(2)}/20</strong>
                </div>
                <hr>
            `;
        }
    }
}

      
      async function loadPresenceStats() {
    if (!currentEleve) {
        document.getElementById('presenceStatsContainer').innerHTML = '<p style="color:#6c757d;">Veuillez vous connecter d\'abord</p>';
        return;
    }
    
    const periode = document.getElementById('periodePresence').value;
    let query = db.collection('presences').where('matricule', '==', currentEleve.matricule);
    
    const today = new Date();
    let startDate = null;
    
    if (periode === 'week') {
        const startOfWeek = new Date(today);
        startOfWeek.setDate(today.getDate() - today.getDay());
        startDate = startOfWeek.toISOString().split('T')[0];
        query = query.where('date', '>=', startDate);
    } else if (periode === 'month') {
        startDate = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-01`;
        query = query.where('date', '>=', startDate);
    }
    
    const snapshot = await query.get();
    const presences = [];
    snapshot.forEach(doc => presences.push(doc.data()));
    
    // Grouper par date
    const groupedByDate = {};
    presences.forEach(p => {
        if (!groupedByDate[p.date]) {
            groupedByDate[p.date] = [];
        }
        groupedByDate[p.date].push(p);
    });
    
    // Trier les dates du plus récent au plus ancien
    const sortedDates = Object.keys(groupedByDate).sort().reverse();
    
    const container = document.getElementById('presenceStatsContainer');
    
    if (sortedDates.length === 0) {
        container.innerHTML = '<p style="color:#6c757d; text-align:center; padding:40px;">Aucun enregistrement de présence</p>';
        return;
    }
    
    // Statistiques globales
    let totalAbsences = 0;
    let totalRetards = 0;
    let joursAvecAbsence = 0;
    
    sortedDates.forEach(date => {
        const dayPresences = groupedByDate[date];
        const absents = dayPresences.filter(p => p.statut === 'Absent');
        const retards = dayPresences.filter(p => p.statut === 'Retard');
        totalAbsences += absents.length;
        totalRetards += retards.length;
        if (absents.length > 0 || retards.length > 0) joursAvecAbsence++;
    });
    
    container.innerHTML = `
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(150px,1fr)); gap:16px; margin-bottom:24px;">
            <div style="background:#f8fafc; border-radius:12px; padding:16px; text-align:center;">
                <div style="font-size:28px; font-weight:700; color:#2c3e50;">${sortedDates.length}</div>
                <div style="font-size:12px; color:#6c757d;">Jours enregistrés</div>
            </div>
            <div style="background:#fef2f2; border-radius:12px; padding:16px; text-align:center;">
                <div style="font-size:28px; font-weight:700; color:#ef4444;">${totalAbsences}</div>
                <div style="font-size:12px; color:#6c757d;">Total absences</div>
            </div>
            <div style="background:#fff7ed; border-radius:12px; padding:16px; text-align:center;">
                <div style="font-size:28px; font-weight:700; color:#f59e0b;">${totalRetards}</div>
                <div style="font-size:12px; color:#6c757d;">Total retards</div>
            </div>
            <div style="background:#f0fdf4; border-radius:12px; padding:16px; text-align:center;">
                <div style="font-size:28px; font-weight:700; color:#10b981;">${sortedDates.length - joursAvecAbsence}</div>
                <div style="font-size:12px; color:#6c757d;">Jours parfaits</div>
            </div>
        </div>
        
        <div style="margin-top:20px;">
            <h4 style="margin-bottom:16px; color:#2c3e50;"><i class="fas fa-list"></i> Détail par jour</h4>
            <div style="background:white; border-radius:16px; border:1px solid #edf2f7; overflow:hidden;">
                ${sortedDates.map(date => {
                    const dayPresences = groupedByDate[date];
                    const absents = dayPresences.filter(p => p.statut === 'Absent');
                    const retards = dayPresences.filter(p => p.statut === 'Retard');
                    
                    const dateObj = new Date(date);
                    const formattedDate = dateObj.toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
                    
                    const aDesAbsences = absents.length > 0;
                    const aDesRetards = retards.length > 0;
                    
                    if (!aDesAbsences && !aDesRetards) {
                        return `
                            <div style="border-bottom:1px solid #edf2f7; background:#f0fdf4;">
                                <div style="padding:16px 20px; display:flex; justify-content:space-between; align-items:center;">
                                    <div>
                                        <i class="fas fa-calendar-day" style="color:#10b981; margin-right:12px;"></i>
                                        <strong>${formattedDate}</strong>
                                    </div>
                                    <span style="background:#f0fdf4; color:#10b981; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:600;">
                                        <i class="fas fa-check-circle"></i> Journée complète ✅
                                    </span>
                                </div>
                            </div>
                        `;
                    }
                    
                    return `
                        <div style="border-bottom:1px solid #edf2f7;">
                            <div class="presence-day-header" onclick="togglePresenceDay('${date}')" style="padding:16px 20px; cursor:pointer; display:flex; justify-content:space-between; align-items:center; background:${aDesAbsences ? '#fef2f2' : '#fff7ed'}; transition:all 0.2s;">
                                <div>
                                    <i class="fas fa-calendar-day" style="color:${aDesAbsences ? '#ef4444' : '#f59e0b'}; margin-right:12px;"></i>
                                    <strong>${formattedDate}</strong>
                                    <div style="margin-top:6px;">
                                        ${aDesAbsences ? `<span style="background:#fef2f2; color:#ef4444; padding:2px 8px; border-radius:12px; font-size:11px; margin-right:8px;"><i class="fas fa-user-slash"></i> ${absents.length} absence(s)</span>` : ''}
                                        ${aDesRetards ? `<span style="background:#fff7ed; color:#f59e0b; padding:2px 8px; border-radius:12px; font-size:11px;"><i class="fas fa-clock"></i> ${retards.length} retard(s)</span>` : ''}
                                    </div>
                                </div>
                                <div>
                                    <i class="fas fa-chevron-down" id="chevron-${date}" style="transition:transform 0.2s; color:#6c757d;"></i>
                                </div>
                            </div>
                            <div id="day-detail-${date}" style="display:none; padding:0 20px 20px 20px; background:white;">
                                ${aDesAbsences ? `
                                    <div style="margin-top:16px; background:#fef2f2; border-radius:12px; padding:16px;">
                                        <h5 style="font-size:13px; color:#ef4444; margin-bottom:12px;"><i class="fas fa-user-slash"></i> Absences</h5>
                                        ${absents.map(a => `
                                            <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid #fef2f2;">
                                                <div>
                                                    <i class="fas fa-hourglass-half"></i> ${a.horaire || 'Horaire non précisé'}
                                                </div>
                                                <span style="background:#fef2f2; color:#ef4444; padding:2px 8px; border-radius:12px; font-size:11px;">Absent</span>
                                            </div>
                                        `).join('')}
                                    </div>
                                ` : ''}
                                
                                ${aDesRetards ? `
                                    <div style="margin-top:16px; background:#fff7ed; border-radius:12px; padding:16px;">
                                        <h5 style="font-size:13px; color:#f59e0b; margin-bottom:12px;"><i class="fas fa-clock"></i> Retards</h5>
                                        ${retards.map(r => `
                                            <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid #fff7ed;">
                                                <div>
                                                    <i class="fas fa-hourglass-start"></i> ${r.horaire || 'Horaire non précisé'}
                                                </div>
                                                <span style="background:#fff7ed; color:#f59e0b; padding:2px 8px; border-radius:12px; font-size:11px;">Retard</span>
                                            </div>
                                        `).join('')}
                                    </div>
                                ` : ''}
                            </div>
                        </div>
                    `;
                }).join('')}
            </div>
        </div>
    `;
}

// Fonction pour afficher/masquer les détails d'un jour
function togglePresenceDay(date) {
    const detail = document.getElementById(`day-detail-${date}`);
    const chevron = document.getElementById(`chevron-${date}`);
    
    if (detail.style.display === 'none') {
        detail.style.display = 'block';
        if (chevron) chevron.style.transform = 'rotate(180deg)';
    } else {
        detail.style.display = 'none';
        if (chevron) chevron.style.transform = 'rotate(0deg)';
    }
}
        async function soumettreDemande() {
            const typeDocument = document.getElementById('typeDocument').value;
            const motif = document.getElementById('motifDemande').value;
            const messageDiv = document.getElementById('demandeMessage');
            
            if (!motif) {
                messageDiv.innerHTML = '<div class="demande-message message-error">❌ Veuillez entrer un motif</div>';
                return;
            }
            
            const demandeData = {
                typeDocument,
                motif,
                date: new Date().toISOString(),
                statut: 'En attente',
                nomComplet: currentEleve ? currentEleve.nom : 'Non connecté',
                matricule: currentEleve ? currentEleve.matricule : 'Non connecté'
            };
            
            await db.collection('demandes').add(demandeData);
            messageDiv.innerHTML = '<div class="demande-message message-success">✅ Demande soumise avec succès!</div>';
            document.getElementById('motifDemande').value = '';
            
            setTimeout(() => {
                messageDiv.innerHTML = '';
            }, 3000);
        }

        function logoutParent() {
            currentEleve = null;
            document.getElementById('loginFormParent').style.display = 'block';
            document.getElementById('eleveInfo').style.display = 'none';
            document.getElementById('matriculeLogin').value = '';
            document.getElementById('dateNaissanceLogin').value = '';
            document.getElementById('nomLogin').value = '';
            document.getElementById('telephoneLogin').value = '';
            document.getElementById('emailLogin').value = '';
        }

        // Initialisation
        loadActualites();
    </script>
