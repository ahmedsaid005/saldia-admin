        function setStatus(matricule, status) {
            currentPresences[matricule] = status;
            updateRowsColor();
        }

        function updateRowsColor() {
            currentStudents.forEach(student => {
                const row = document.getElementById(`row_${student.matricule}`);
                if (row) {
                    row.className = '';
                    const status = currentPresences[student.matricule];
                    if (status === 'Présent') row.classList.add('present-row');
                    else if (status === 'Absent') row.classList.add('absent-row');
                    else if (status === 'Retard') row.classList.add('retard-row');
                    
                    const btns = row.querySelectorAll('.status-btn');
                    btns.forEach(btn => {
                        btn.classList.remove('active');
                        if ((status === 'Présent' && btn.classList.contains('present')) ||
                            (status === 'Absent' && btn.classList.contains('absent')) ||
                            (status === 'Retard' && btn.classList.contains('retard'))) {
                            btn.classList.add('active');
                        }
                    });
                }
            });
        }

        async function loadExistingPresences() {
            const date = document.getElementById('presenceDate').value;
            const timeSelect = document.getElementById('presenceTime');
            const selectedTimes = Array.from(timeSelect.selectedOptions).map(opt => opt.value);
            
            if (selectedTimes.length === 0) return;
            
            for (const student of currentStudents) {
                let hasAnyPresence = false;
                for (const timeSlot of selectedTimes) {
                    const presenceId = `${student.matricule}_${date}_${timeSlot}`;
                    const presenceDoc = await db.collection('presences').doc(presenceId).get();
                    if (presenceDoc.exists) {
                        currentPresences[student.matricule] = presenceDoc.data().statut;
                        hasAnyPresence = true;
                        break;
                    }
                }
                if (!hasAnyPresence) {
                    currentPresences[student.matricule] = 'Présent';
                }
            }
            updateRowsColor();
        }

        async function saveAllPresences(className) {
            const date = document.getElementById('presenceDate').value;
            const timeSelect = document.getElementById('presenceTime');
            const selectedTimes = Array.from(timeSelect.selectedOptions).map(opt => opt.value);
            
            if (selectedTimes.length === 0) {
                alert('Veuillez sélectionner au moins un horaire');
                return;
            }
            
            for (const student of currentStudents) {
                const status = currentPresences[student.matricule] || 'Présent';
                for (const timeSlot of selectedTimes) {
                    const presenceId = `${student.matricule}_${date}_${timeSlot}`;
                    await db.collection('presences').doc(presenceId).set({
                        matricule: student.matricule,
                        nom: student.nom,
                        classe: className,
                        date: date,
                        horaire: timeSlot,
                        statut: status,
                        matiere: currentProf.matiere,
                        professeur: currentProf.nom,
                        timestamp: new Date().toISOString()
                    });
                }
            }
            alert('Présences enregistrées avec succès !');
            await loadExistingPresences();
        }

