    // Grouper par élève
    const studentsMap = {};
    presences.forEach(p => {
        if (!studentsMap[p.matricule]) {
            studentsMap[p.matricule] = {
                nom: p.nom,
                matricule: p.matricule,
                presences: []
            };
        }
        studentsMap[p.matricule].presences.push({
            horaire: p.horaire,
            statut: p.statut
        });
    });
    
    const studentsList = Object.values(studentsMap);
    const dateObj = new Date(date);
    const formattedDate = dateObj.toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    
    const container = document.getElementById('historyList');
    container.innerHTML = `
        <button class="back-link" onclick="loadHistory()" style="margin-bottom:20px;">
            <i class="fas fa-arrow-left"></i> Retour à l'historique
        </button>
        
        <div style="background:white; border-radius:16px; border:1px solid #edf2f7; padding:24px;">
            <div style="margin-bottom:24px;">
                <h3 style="font-size:18px; margin-bottom:4px;">${formattedDate}</h3>
                <p style="font-size:13px; color:#6c757d;">Détail complet des présences</p>
            </div>
            
            <div class="students-table-wrapper">
                <table class="students-table" style="min-width:800px;">
                    <thead>
                        <tr>
                            <th>Matricule</th>
                            <th>Nom de l'élève</th>
                            <th>Statut général</th>
                            <th>Détails par horaire</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${studentsList.map(student => {
                            const hasAbsence = student.presences.some(p => p.statut === 'Absent');
                            const hasRetard = student.presences.some(p => p.statut === 'Retard');
                            const statutGeneral = hasAbsence ? 'Absent' : (hasRetard ? 'Retard' : 'Présent');
                            const statutColor = hasAbsence ? '#ef4444' : (hasRetard ? '#f59e0b' : '#10b981');
                            
                            return `
                                <tr style="${hasAbsence ? 'background:#fef2f2' : (hasRetard ? 'background:#fff7ed' : 'background:#f0fdf4')}">
                                    <td>${student.matricule}</td>
                                    <td><strong>${student.nom}</strong></td>
                                    <td>
                                        <span style="background:${statutColor}20; color:${statutColor}; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:600;">
                                            ${statutGeneral}
                                        </span>
                                    </td>
                                    <td>
                                        <div style="display:flex; flex-wrap:wrap; gap:6px;">
                                            ${student.presences.map(p => `
                                                <span style="background:${p.statut === 'Présent' ? '#f0fdf4' : (p.statut === 'Absent' ? '#fef2f2' : '#fff7ed')}; 
                                                             color:${p.statut === 'Présent' ? '#10b981' : (p.statut === 'Absent' ? '#ef4444' : '#f59e0b')}; 
                                                             padding:4px 8px; border-radius:8px; font-size:11px;">
                                                    ${p.horaire || '?'}: ${p.statut}
                                                </span>
                                            `).join('')}
                                        </div>
                                    </td>
                                </tr>
                            `;
                        }).join('')}
                    </tbody>
                </table>
            </div>
        </div>
    `;
}

// Fonction pour afficher/masquer les détails d'une date
function toggleDateGroup(date) {
    const content = document.getElementById(`date-group-${date}`);
    const header = content.previousElementSibling;
    const icon = header.querySelector('.fa-chevron-down');
    
    if (content.style.display === 'none') {
        content.style.display = 'block';
        if (icon) icon.style.transform = 'rotate(180deg)';
    } else {
        content.style.display = 'none';
        if (icon) icon.style.transform = 'rotate(0deg)';
    }
}

        async function updateProfile() {
            const newPassword = document.getElementById('newPassword').value;
            if (newPassword) {
                await db.collection('professeurs').doc(currentProf.id).update({ password: newPassword });
                alert('Mot de passe mis à jour');
                document.getElementById('newPassword').value = '';
            }
        }

        function logout() {
            currentProf = null;
            document.getElementById('loginSection').style.display = 'block';
            document.getElementById('mainSection').style.display = 'none';
            document.getElementById('bottomNav').style.display = 'none';
        }

        function showPanel(panelId) {
            document.querySelectorAll('.content-panel').forEach(panel => panel.classList.remove('active'));
            document.getElementById(panelId).classList.add('active');
            if (panelId === 'historyPanel') loadHistory();
        }

        window.onload = () => {
            const today = new Date().toISOString().split('T')[0];
            if(document.getElementById('historyStartDate')) 
                document.getElementById('historyStartDate').value = today;
        };
    </script>
