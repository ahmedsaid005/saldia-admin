<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Gestion des présences - Espace Professeur</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding-bottom: 80px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Login Section */
        .login-container {
            background: white;
            border-radius: 30px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            margin-top: 50px;
            max-width: 400px;
            margin-left: auto;
            margin-right: auto;
        }

        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .login-header h1 {
            color: #667eea;
            font-size: 2em;
            margin-bottom: 10px;
        }

        .login-header p {
            color: #666;
        }

        /* Main Container */
        .main-container {
            display: none;
        }

        /* Header */
        .dashboard-header {
            background: white;
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 30px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }

        .dashboard-header h1 {
            color: #667eea;
            font-size: 1.8em;
            margin-bottom: 5px;
        }

        .dashboard-header p {
            color: #666;
            font-size: 1.1em;
        }

        /* Bottom Navigation */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: white;
            display: flex;
            justify-content: space-around;
            padding: 12px 20px;
            box-shadow: 0 -5px 20px rgba(0,0,0,0.1);
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .nav-btn {
            flex: 1;
            margin: 0 8px;
            padding: 12px;
            background: #f5f5f5;
            color: #667eea;
            border: none;
            border-radius: 15px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .nav-btn.active {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102,126,234,0.4);
        }

        /* Content Panels */
        .content-panel {
            display: none;
            animation: fadeIn 0.4s ease-out;
        }

        .content-panel.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Cards */
        .class-card {
            background: white;
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: transform 0.2s, box-shadow 0.2s;
            cursor: pointer;
        }

        .class-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        }

        .class-info h3 {
            color: #333;
            margin-bottom: 5px;
        }

        .class-info p {
            color: #666;
            font-size: 0.9em;
        }

        .view-btn {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 600;
            transition: transform 0.2s;
        }

        .view-btn:hover {
            transform: scale(1.05);
        }

        /* Student Table - Horizontal Layout */
        .students-table-container {
            background: white;
            border-radius: 20px;
            padding: 20px;
            overflow-x: auto;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }

        .header-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .back-btn {
            background: #f5f5f5;
            color: #667eea;
            border: none;
            padding: 10px 20px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .date-time-selector {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 15px;
            margin-bottom: 20px;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            align-items: flex-end;
        }

        .date-group, .time-group {
            flex: 1;
            min-width: 200px;
        }

        .date-group label, .time-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #333;
            font-size: 0.9em;
        }

        .date-group input, .time-group select {
            width: 100%;
            padding: 10px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 14px;
            transition: border-color 0.2s;
        }

        .date-group input:focus, .time-group select:focus {
            outline: none;
            border-color: #667eea;
        }

        .time-group select {
            cursor: pointer;
        }

        .students-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 800px;
        }

        .students-table th {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            padding: 15px;
            text-align: left;
            font-weight: 600;
            position: sticky;
            top: 0;
        }

        .students-table td {
            padding: 15px;
            border-bottom: 1px solid #e0e0e0;
            vertical-align: middle;
        }

        .students-table tr:hover {
            background: #f9f9f9;
        }

        .student-photo {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            object-fit: cover;
        }

        .status-buttons {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .status-btn {
            padding: 6px 12px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-size: 0.85em;
            font-weight: 600;
            transition: all 0.2s;
        }

        .status-btn.present {
            background: #4CAF50;
            color: white;
        }

        .status-btn.absent {
            background: #f44336;
            color: white;
        }

        .status-btn.retard {
            background: #ff9800;
            color: white;
        }

        .status-btn.active {
            transform: scale(0.95);
            box-shadow: inset 0 2px 5px rgba(0,0,0,0.2);
        }

        .status-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .save-all-btn {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 600;
            font-size: 1em;
            margin-top: 20px;
            width: 100%;
        }

        /* Notes Panel - Bulk Entry */
        .notes-options {
            background: white;
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }

        .form-row {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .form-field {
            flex: 1;
            min-width: 200px;
        }

        .form-field label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #333;
        }

        .form-field input, .form-field select {
            width: 100%;
            padding: 12px;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            font-size: 14px;
        }

        .notes-bulk-table {
            background: white;
            border-radius: 20px;
            padding: 20px;
            overflow-x: auto;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }

        .notes-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 600px;
        }

        .notes-table th {
            background: #667eea;
            color: white;
            padding: 12px;
            text-align: left;
        }

        .notes-table td {
            padding: 12px;
            border-bottom: 1px solid #e0e0e0;
        }

        .note-input {
            width: 80px;
            padding: 8px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            text-align: center;
        }

        .appreciation-input {
            width: 100%;
            padding: 8px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 12px;
        }

        .save-notes-btn {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 600;
            margin-top: 20px;
            width: 100%;
        }

        /* History Panel */
        .history-filters {
            background: white;
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .history-list {
            background: white;
            border-radius: 20px;
            padding: 20px;
            max-height: 500px;
            overflow-y: auto;
        }

        .history-item {
            border-left: 4px solid #667eea;
            padding: 15px;
            margin-bottom: 10px;
            background: #f9f9f9;
            border-radius: 10px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .container {
                padding: 10px;
            }
            
            .status-buttons {
                flex-direction: column;
            }
            
            .status-btn {
                width: 100%;
            }
            
            .nav-btn span {
                display: none;
            }
            
            .nav-btn {
                font-size: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Login Section -->
        <div id="loginSection" class="login-container">
            <div class="login-header">
                <h1>👨‍🏫 Espace Professeur</h1>
                <p>Gestion des présences et des notes</p>
            </div>
            <div class="form-group">
                <label>📧 Identifiant</label>
                <input type="text" id="loginId" placeholder="Entrez votre identifiant">
            </div>
            <div class="form-group">
                <label>🔒 Mot de passe</label>
                <input type="password" id="loginPassword" placeholder="Entrez votre mot de passe">
            </div>
            <button onclick="login()">Se connecter</button>
        </div>

        <!-- Main Section -->
        <div id="mainSection" class="main-container">
            <div class="dashboard-header">
                <h1 id="profName"></h1>
                <p id="profMatiere"></p>
            </div>

            <!-- Classes Panel -->
            <div id="classesPanel" class="content-panel active">
                <h2 style="color: white; margin-bottom: 20px;">📚 Mes classes</h2>
                <div id="classesList"></div>
            </div>

            <!-- Presence Panel -->
            <div id="presencePanel" class="content-panel">
                <div id="presenceContent"></div>
            </div>

            <!-- Notes Panel -->
            <div id="notesPanel" class="content-panel">
                <div class="notes-options">
                    <h3 style="margin-bottom: 20px;">📝 Saisie des notes</h3>
                    <div class="form-row">
                        <div class="form-field">
                            <label>Classe</label>
                            <select id="noteClasse" onchange="loadElevesForNotes()">
                                <option value="">Sélectionner une classe</option>
                            </select>
                        </div>
                        <div class="form-field">
                            <label>Type d'évaluation</label>
                            <select id="noteType">
                                <option value="CC1">CC1</option>
                                <option value="CC2">CC2</option>
                                <option value="Composition">Composition</option>
                            </select>
                        </div>
                        <div class="form-field">
                            <label>Semestre</label>
                            <select id="noteSemestre">
                                <option value="1">Semestre 1</option>
                                <option value="2">Semestre 2</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div id="notesBulkList" class="notes-bulk-table"></div>
            </div>

            <!-- History Panel -->
            <div id="historyPanel" class="content-panel">
                <div class="history-filters">
                    <h3 style="margin-bottom: 20px;">📜 Historique des présences</h3>
                    <div class="form-row">
                        <div class="form-field">
                            <label>Date début</label>
                            <input type="date" id="historyStartDate">
                        </div>
                        <div class="form-field">
                            <label>Date fin</label>
                            <input type="date" id="historyEndDate">
                        </div>
                        <div class="form-field">
                            <label>Élève</label>
                            <input type="text" id="historyStudentName" placeholder="Nom de l'élève">
                        </div>
                        <div class="form-field">
                            <button onclick="loadHistory()" style="margin-top: 32px;">🔍 Rechercher</button>
                        </div>
                    </div>
                </div>
                <div id="historyList" class="history-list"></div>
            </div>

            <!-- Profile Panel -->
            <div id="profilePanel" class="content-panel">
                <div style="background: white; border-radius: 20px; padding: 30px;">
                    <h3 style="margin-bottom: 20px;">👤 Mon profil</h3>
                    <div class="form-field">
                        <label>Identifiant</label>
                        <input type="text" id="profileId" readonly>
                    </div>
                    <div class="form-field">
                        <label>Nom complet</label>
                        <input type="text" id="profileNom" readonly>
                    </div>
                    <div class="form-field">
                        <label>Matière</label>
                        <input type="text" id="profileMatiere" readonly>
                    </div>
                    <div class="form-field">
                        <label>Nouveau mot de passe</label>
                        <input type="password" id="newPassword" placeholder="Laissez vide pour ne pas changer">
                    </div>
                    <button onclick="updateProfile()">Mettre à jour</button>
                    <button onclick="logout()" style="margin-top: 10px; background: #f44336;">Se déconnecter</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Navigation -->
    <div class="bottom-nav" id="bottomNav" style="display:none;">
        <button class="nav-btn active" onclick="showPanel('classesPanel')">📚 Classes</button>
        <button class="nav-btn" onclick="showPanel('notesPanel')">📝 Notes</button>
        <button class="nav-btn" onclick="showPanel('historyPanel')">📜 Historique</button>
        <button class="nav-btn" onclick="showPanel('profilePanel')">👤 Profil</button>
    </div>

    <script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-firestore-compat.js"></script>
    <script>
        const firebaseConfig = {
            apiKey: "AIzaSyC2AC5ZBXkHmtQhuksZnzt0B2sl-d8bvAg",
            authDomain: "teste-saldia.firebaseapp.com",
            projectId: "teste-saldia",
            storageBucket: "teste-saldia.firebasestorage.app",
            messagingSenderId: "620601259237",
            appId: "1:620601259237:web:57795c7a64082399d0d00c"
        };

        firebase.initializeApp(firebaseConfig);
        const db = firebase.firestore();

        let currentProf = null;
        let currentStudents = [];
        let currentPresences = {};

        // Créneaux horaires
        const timeSlots = [
            "08:00 - 09:00", "09:00 - 10:00", "10:00 - 10:50", "10:50 - 11:05",
            "11:05 - 12:05", "12:05 - 13:05", "13:05 - 13:35", "13:35 - 14:35",
            "14:35 - 15:35", "15:35 - 16:35", "16:35 - 17:35"
        ];

        async function login() {
            const id = document.getElementById('loginId').value;
            const password = document.getElementById('loginPassword').value;
            
            const profDoc = await db.collection('professeurs').doc(id).get();
            if (profDoc.exists && profDoc.data().password === password) {
                currentProf = { id, ...profDoc.data() };
                document.getElementById('loginSection').style.display = 'none';
                document.getElementById('mainSection').style.display = 'block';
                document.getElementById('bottomNav').style.display = 'flex';
                document.getElementById('profName').textContent = `Bienvenue ${currentProf.nom}`;
                document.getElementById('profMatiere').textContent = `Professeur de ${currentProf.matiere}`;
                document.getElementById('profileId').value = currentProf.id;
                document.getElementById('profileNom').value = currentProf.nom;
                document.getElementById('profileMatiere').value = currentProf.matiere;
                loadMyClasses();
                loadClassesForNotes();
                showPanel('classesPanel');
            } else {
                alert('Identifiant ou mot de passe incorrect');
            }
        }

        async function loadMyClasses() {
            const container = document.getElementById('classesList');
            container.innerHTML = '';
            
            for (const className of currentProf.classes) {
                const classCard = document.createElement('div');
                classCard.className = 'class-card';
                classCard.innerHTML = `
                    <div class="class-info">
                        <h3>📖 ${className}</h3>
                        <p>${currentProf.matiere}</p>
                    </div>
                    <button class="view-btn" onclick="showPresencePanel('${className}')">Gérer les présences</button>
                `;
                container.appendChild(classCard);
            }
        }

        async function showPresencePanel(className) {
            // Charger les élèves
            const studentsSnapshot = await db.collection('eleves').where('classe', '==', className).get();
            currentStudents = [];
            studentsSnapshot.forEach(doc => currentStudents.push({ id: doc.id, ...doc.data() }));
            
            // Initialiser la date du jour
            const today = new Date().toISOString().split('T')[0];
            
            const container = document.getElementById('presenceContent');
            container.innerHTML = `
                <div class="students-table-container">
                    <div class="header-actions">
                        <button class="back-btn" onclick="showPanel('classesPanel')">← Retour aux classes</button>
                        <h3>${className} - ${currentProf.matiere}</h3>
                    </div>
                    
                    <div class="date-time-selector">
                        <div class="date-group">
                            <label>📅 Date du cours</label>
                            <input type="date" id="presenceDate" value="${today}" onchange="loadExistingPresences()">
                        </div>
                        <div class="time-group">
                            <label>⏰ Horaire du cours</label>
                            <select id="presenceTime">
                                ${timeSlots.map(slot => `<option value="${slot}">${slot}</option>`).join('')}
                            </select>
                        </div>
                    </div>
                    
                    <div class="students-table-container">
                        <table class="students-table">
                            <thead>
                                <tr>
                                    <th>Photo</th>
                                    <th>Matricule</th>
                                    <th>Nom complet</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody id="studentsTableBody">
                                ${currentStudents.map(student => `
                                    <tr>
                                        <td><img src="${student.photoUrl}" class="student-photo" onerror="this.src='https://via.placeholder.com/45'"></td>
                                        <td>${student.matricule}</td>
                                        <td><strong>${student.nom}</strong></td>
                                        <td>
                                            <div class="status-buttons">
                                                <button class="status-btn present" onclick="setStatus('${student.matricule}', 'Présent')">✅ Présent</button>
                                                <button class="status-btn absent" onclick="setStatus('${student.matricule}', 'Absent')">❌ Absent</button>
                                                <button class="status-btn retard" onclick="setStatus('${student.matricule}', 'Retard')">⏰ Retard</button>
                                            </div>
                                        </td>
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                    
                    <button class="save-all-btn" onclick="saveAllPresences('${className}')">💾 Enregistrer toutes les présences</button>
                </div>
            `;
            
            currentPresences = {};
            await loadExistingPresences();
            showPanel('presencePanel');
        }

        function setStatus(matricule, status) {
            currentPresences[matricule] = status;
            // Mettre à jour l'affichage des boutons
            const row = document.querySelector(`tr:has(button[onclick*="${matricule}"])`);
            if (row) {
                const buttons = row.querySelectorAll('.status-btn');
                buttons.forEach(btn => {
                    btn.classList.remove('active');
                    if ((status === 'Présent' && btn.classList.contains('present')) ||
                        (status === 'Absent' && btn.classList.contains('absent')) ||
                        (status === 'Retard' && btn.classList.contains('retard'))) {
                        btn.classList.add('active');
                    }
                });
            }
        }

        async function loadExistingPresences() {
            const date = document.getElementById('presenceDate').value;
            const timeSlot = document.getElementById('presenceTime').value;
            
            for (const student of currentStudents) {
                const presenceId = `${student.matricule}_${date}_${timeSlot}`;
                const presenceDoc = await db.collection('presences').doc(presenceId).get();
                if (presenceDoc.exists) {
                    currentPresences[student.matricule] = presenceDoc.data().statut;
                    const row = document.querySelector(`tr:has(button[onclick*="${student.matricule}"])`);
                    if (row) {
                        const buttons = row.querySelectorAll('.status-btn');
                        buttons.forEach(btn => {
                            btn.classList.remove('active');
                            if ((presenceDoc.data().statut === 'Présent' && btn.classList.contains('present')) ||
                                (presenceDoc.data().statut === 'Absent' && btn.classList.contains('absent')) ||
                                (presenceDoc.data().statut === 'Retard' && btn.classList.contains('retard'))) {
                                btn.classList.add('active');
                            }
                        });
                    }
                }
            }
        }

        async function saveAllPresences(className) {
            const date = document.getElementById('presenceDate').value;
            const timeSlot = document.getElementById('presenceTime').value;
            
            for (const student of currentStudents) {
                const status = currentPresences[student.matricule] || 'Présent'; // Par défaut présent
                const presenceId = `${student.matricule}_${date}_${timeSlot}`;
                
                await db.collection('presences').doc(presenceId).set({
                    matricule: student.matricule,
                    nom: student.nom,
                    classe: className,
                    date: date,
                    horaire: timeSlot,
                    statut: status,
                    matiere: currentProf.matiere,
                    professeur: currentProf.nom,
                    timestamp: new Date().toISOString()
                });
            }
            
            alert('✅ Toutes les présences ont été enregistrées avec succès !');
            await loadExistingPresences();
        }

        async function loadClassesForNotes() {
            const select = document.getElementById('noteClasse');
            select.innerHTML = '<option value="">Sélectionner une classe</option>';
            for (const className of currentProf.classes) {
                select.innerHTML += `<option value="${className}">${className}</option>`;
            }
        }

        async function loadElevesForNotes() {
            const classe = document.getElementById('noteClasse').value;
            const noteType = document.getElementById('noteType').value;
            const semestre = document.getElementById('noteSemestre').value;
            
            if (!classe) return;
            
            const studentsSnapshot = await db.collection('eleves').where('classe', '==', classe).get();
            const students = [];
            studentsSnapshot.forEach(doc => students.push({ id: doc.id, ...doc.data() }));
            
            const container = document.getElementById('notesBulkList');
            container.innerHTML = `
                <table class="notes-table">
                    <thead>
                        <tr>
                            <th>Matricule</th>
                            <th>Nom de l'élève</th>
                            <th>Note /20</th>
                            <th>Appréciation</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${students.map(student => `
                            <tr>
                                <td>${student.matricule}</td>
                                <td><strong>${student.nom}</strong></td>
                                <td>
                                    <input type="number" class="note-input" id="note_${student.matricule}" 
                                           step="0.25" min="0" max="20" placeholder="Note">
                                </td>
                                <td>
                                    <input type="text" class="appreciation-input" id="appreciation_${student.matricule}" 
                                           placeholder="Appréciation">
                                </td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
                <button class="save-notes-btn" onclick="saveAllNotes('${classe}')">💾 Enregistrer toutes les notes</button>
            `;
            
            // Charger les notes existantes
            for (const student of students) {
                const noteId = `${student.matricule}_${currentProf.matiere}_${semestre}_${noteType}`;
                const noteDoc = await db.collection('notes').doc(noteId).get();
                if (noteDoc.exists) {
                    document.getElementById(`note_${student.matricule}`).value = noteDoc.data().note;
                    document.getElementById(`appreciation_${student.matricule}`).value = noteDoc.data().appreciation || '';
                }
            }
        }

        async function saveAllNotes(classe) {
            const studentsSnapshot = await db.collection('eleves').where('classe', '==', classe).get();
            const students = [];
            studentsSnapshot.forEach(doc => students.push({ id: doc.id, ...doc.data() }));
            
            const noteType = document.getElementById('noteType').value;
            const semestre = document.getElementById('noteSemestre').value;
            
            for (const student of students) {
                const noteValue = document.getElementById(`note_${student.matricule}`).value;
                const appreciation = document.getElementById(`appreciation_${student.matricule}`).value;
                
                if (noteValue) {
                    const noteId = `${student.matricule}_${currentProf.matiere}_${semestre}_${noteType}`;
                    await db.collection('notes').doc(noteId).set({
                        eleveId: student.matricule,
                        eleveNom: student.nom,
                        classe: classe,
                        matiere: currentProf.matiere,
                        semestre: semestre,
                        type: noteType,
                        note: parseFloat(noteValue),
                        appreciation: appreciation,
                        professeur: currentProf.nom,
                        date: new Date().toISOString()
                    });
                }
            }
            
            alert('✅ Toutes les notes ont été enregistrées avec succès !');
        }

        async function loadHistory() {
            const startDate = document.getElementById('historyStartDate').value;
            const endDate = document.getElementById('historyEndDate').value;
            const studentName = document.getElementById('historyStudentName').value.toLowerCase();
            
            let query = db.collection('presences');
            
            if (startDate) {
                query = query.where('date', '>=', startDate);
            }
            if (endDate) {
                query = query.where('date', '<=', endDate);
            }
            
            const snapshot = await query.get();
            let presences = [];
            snapshot.forEach(doc => presences.push(doc.data()));
            
            if (studentName) {
                presences = presences.filter(p => p.nom.toLowerCase().includes(studentName));
            }
            
            const container = document.getElementById('historyList');
            if (presences.length === 0) {
                container.innerHTML = '<p style="text-align: center; padding: 40px;">Aucun enregistrement trouvé</p>';
                return;
            }
            
            container.innerHTML = presences.map(p => `
                <div class="history-item">
                    <strong>📅 ${p.date}</strong> - ${p.horaire || 'Horaire non spécifié'}<br>
                    <strong>👨‍🎓 ${p.nom}</strong> (${p.matricule})<br>
                    <strong>📚 ${p.classe}</strong> - ${p.matiere || currentProf.matiere}<br>
                    <strong>Statut:</strong> 
                    <span style="color: ${p.statut === 'Présent' ? '#4CAF50' : p.statut === 'Absent' ? '#f44336' : '#ff9800'}">
                        ${p.statut === 'Présent' ? '✅' : p.statut === 'Absent' ? '❌' : '⏰'} ${p.statut}
                    </span><br>
                    <strong>Professeur:</strong> ${p.professeur}
                </div>
            `).join('');
        }

        async function updateProfile() {
            const newPassword = document.getElementById('newPassword').value;
            if (newPassword) {
                await db.collection('professeurs').doc(currentProf.id).update({
                    password: newPassword
                });
                alert('✅ Mot de passe mis à jour');
                document.getElementById('newPassword').value = '';
            }
        }

        function logout() {
            currentProf = null;
            document.getElementById('loginSection').style.display = 'block';
            document.getElementById('mainSection').style.display = 'none';
            document.getElementById('bottomNav').style.display = 'none';
            document.getElementById('loginId').value = '';
            document.getElementById('loginPassword').value = '';
        }

        function showPanel(panelId) {
            document.querySelectorAll('.content-panel').forEach(panel => {
                panel.classList.remove('active');
            });
            document.getElementById(panelId).classList.add('active');
            
            if (panelId === 'historyPanel') {
                loadHistory();
            }
        }

        // Initialiser la date du jour par défaut
        window.onload = function() {
            const today = new Date().toISOString().split('T')[0];
            if (document.getElementById('historyStartDate')) {
                document.getElementById('historyStartDate').value = today;
            }
        };
    </script>
</body>
</html>
